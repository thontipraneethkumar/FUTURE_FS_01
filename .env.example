# Copy this file to .env (locally) or set these in your Vercel / Netlify
# project's Environment Variables dashboard. Never commit a real .env file.

# SMTP server that will send the email on your behalf.
# Example for Gmail: smtp.gmail.com
SMTP_HOST=smtp.gmail.com

# 587 for STARTTLS (most common), 465 for SSL
SMTP_PORT=587

# The mailbox that sends the email — for Gmail this is your full address
SMTP_USER=youraddress@gmail.com

# An app password, NOT your normal account password.
# Gmail: Google Account -> Security -> 2-Step Verification -> App passwords
SMTP_PASS=your-16-char-app-password

# Where contact form messages get delivered (usually your own email)
CONTACT_TO_EMAIL=248r1a66j.tpk@gmail.com
